# 海豚：安全中心 → 令牌管理 → 复制到下面任一变量（可同时只配 GIDO_DS_TOKEN）
GIDO_DS_TOKEN=
# DS_TOKEN=

# 不配 Token 时可改用登录（不推荐生产）；docker-compose 对应 GIDO_DS_USERNAME / GIDO_DS_PASSWORD
# DS_USERNAME=admin
# DS_PASSWORD=

# 浏览器里打开海豚控制台（本机海豚默认如下；海豚不在本机或端口不同时改此项）
# GIDO_DS_UI_URL=http://localhost:12345/dolphinscheduler/ui

# 一键全栈（PG + Kafka + Flink + Dolphin + GIDO）见仓库根目录：
#   ./start-platform.sh
#   docker compose -f docker-compose-platform.yml up -d --build
# 同网默认无需 host.docker.internal；全栈用 ./start-platform.sh（include gido/docker-compose.yml）。
# 仅单独起 GIDO：cd gido && ./start.sh（勿与全栈同时跑，container_name 相同会冲突）。
#
# GIDO_BIND_HOST=0.0.0.0          # 默认全网卡监听，局域网可访问 http://192.168.x.x:3002
# GIDO_BIND_HOST=127.0.0.1        # 仅本机（OrbStack 端口异常时可改回）
# GIDO_UI_PORT=3002
# GIDO_API_PORT=8001

# Kafka 外网 advertised（bootstrap 须与此 host:port 一致；start-platform.sh 会自动检测 en0 IP）
# KAFKA_LAN_HOST=192.168.1.68

# POSTGRES_IMAGE=postgres:16-alpine
# ZOOKEEPER_IMAGE=zookeeper:3.9
# REDIS_IMAGE=redis:7.4-alpine
#
# GIDO_DATABASE_URL=mysql+pymysql://user:pass@your-mysql-host:3306/gido?charset=utf8mb4
# 首次建表由容器启动时 gido/backend 的 init_db.py 执行（或本地手动跑）

#
# Flink（Session 仅 Kubernetes：k8s/flink.yaml；GIDO 在「系统管理 → 集成」或下列 GIDO_FLINK_* 注入 REST 地址）
#

# JM / Gateway：按你集群 Ingress、LoadBalancer 或 port-forward 填写（示例）
# GIDO_FLINK_URL=http://127.0.0.1:8081
# GIDO_FLINK_SQL_GATEWAY_URL=http://127.0.0.1:8083

# Backend 跑在宿主机（PyCharm）：不要用 host.docker.internal 访问本机映射端口访问 Gateway（常见 Errno 101）
# 也可在 gido/backend/.env 写 FLINK_URL / FLINK_SQL_GATEWAY_URL

# K8s Application 镜像（与 Session 对齐）；或在集成页覆盖
# GIDO_FLINK_K8S_APPLICATION_IMAGE=apache/flink:2.0.1-java11

# Ingress Host（若使用 k8s/flink-sql-gateway-ingress.yaml）
# GIDO_FLINK_SQL_GATEWAY_HTTP_HOST=flink-sql-gateway.localhost
# 备选：后端在集群内 Pod 中可直接 http://flink-sql-gateway.<ns>.svc.cluster.local:8083
