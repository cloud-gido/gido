# 玑渡 GIDO — 环境变量模板（复制为 .env，勿提交 .env）
# 元数据库默认 PostgreSQL；全栈见 ./start-platform.sh

# --- 海豚 DolphinScheduler ---
GIDO_DS_TOKEN=
# GIDO_DS_UI_URL=http://localhost:12345/dolphinscheduler/ui

# --- 端口 / 绑定 ---
# GIDO_BIND_HOST=0.0.0.0
# GIDO_UI_PORT=3002
# GIDO_API_PORT=8001

# --- PostgreSQL 元数据库（与 platform-postgres / k8s/gido.yaml 默认账号一致）---
# GIDO_DATABASE_URL=postgresql+psycopg2://root:DolphinPgDev%2172@host.docker.internal:5432/gido
# 生产推荐拆分：INFRA_GIDO_DB_SERVICE_URL / _USER / _PASSWORD / INFRA_GIDO_DB_URL

# --- Flink Session（SQL；Compose 或 k8s/legacy/flink.yaml，镜像 2.0.1）---
# GIDO_FLINK_URL=http://127.0.0.1:8081
# GIDO_FLINK_SQL_GATEWAY_URL=http://127.0.0.1:8083
# GIDO_FLINK_K8S_APPLICATION_IMAGE=apache/flink:2.0.1-java11

# --- Flink Kubernetes Operator 1.15 + Flink 2.0.1（JAR 生产，与 Session 同版本）---
# GIDO_FLINK_OPERATOR_IMAGE=apache/flink:2.0.1-java11
# GIDO_FLINK_OPERATOR_FLINK_VERSION=v2_0
# 生产 / 集群内 GIDO：见 gido/config/flink-operator.production.env.example
# 本机 Kind 开发覆盖：见 gido/config/flink-operator.kind-local.env.example
# RBAC：kubectl apply -f k8s/flink-operator-rbac.yaml
