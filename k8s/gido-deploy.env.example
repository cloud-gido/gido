# GIDO K3s 一键部署策略（复制为 k8s/gido-deploy.env 后按需修改）
# 加载：deploy-gido-k3s.sh 自动 source；或 export GIDO_DEPLOY_ENV=/path/to/custom.env
#
# ┌─────────────────────────────────────────────────────────────────────────┐
# │ 分层说明（中台产品惯例）                                                  │
# ├──────────────────┬──────────────────────────────────────────────────────┤
# │ 应用层           │ gido-backend / gido-frontend — 你的业务代码，发版必更   │
# │ 运行时层         │ gido-flink-sql-runner — Flink+Connector+SqlRunner 封装 │
# │ 公开基础镜像     │ apache/flink、node、nginx、python — 仅在 docker build  │
# │                  │ 时拉取，不单独部署到 K8s                                 │
# └──────────────────┴──────────────────────────────────────────────────────┘

# ========== 应用层（GIDO 中台）==========
# always：每次 deploy 都从当前工作区构建（推荐）
# never：不构建（仅紧急排障，须 GIDO_ALLOW_SKIP_BUILD=1）
GIDO_DEPLOY_APP_BUILD=always

# fresh：每次生成 app-YYYYMMDD-HHMMSS，配合 Always pull，不用节点旧缓存
# fixed：使用 GIDO_APP_IMAGE_TAG 固定名（须自行保证已 push）
GIDO_DEPLOY_APP_TAG=fresh
# GIDO_APP_IMAGE_TAG=app-manual

# Deployment imagePullPolicy（应用 Pod）
GIDO_DEPLOY_APP_PULL=Always

# ========== 运行时层（Flink 统一运行时）==========
# auto：仅 k8s/flink-sql-runner 源码 hash 变化时构建（推荐）
# always：每次 deploy 都构建（改 Dockerfile / 调 connector 时用）
# never：不构建，使用 registry 已有稳定 tag
GIDO_DEPLOY_FLINK_BUILD=auto

# stable：固定 tag（如 flink-runtime），节点 IfNotPresent 可复用
# fresh：跟应用一样打时间戳（一般不推荐，Flink 包很大）
GIDO_DEPLOY_FLINK_TAG=stable
GIDO_FLINK_RUNTIME_STABLE_TAG=flink-runtime

# 写入 backend ConfigMap 的 FLINK_OPERATOR_IMAGE 对应 tag；Flink Pod 拉取策略由 Operator 控制
# 仅当 GIDO_DEPLOY_FLINK_BUILD=never 时用于跳过 push
GIDO_DEPLOY_FLINK_PULL=IfNotPresent

# 单次强制重建 Flink 运行时（忽略 auto hash）
# GIDO_FORCE_REBUILD_FLINK=1

# ========== 构建选项 ==========
# GIDO_DOCKER_NO_CACHE=1          # docker build 禁用层缓存（慢，一般不必）
# GIDO_K3S_SKIP_RESTART=1         # 节点 registry 已修好、跳过 restart k3s
