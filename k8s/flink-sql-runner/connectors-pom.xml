<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>

    <groupId>com.gido</groupId>
    <artifactId>gido-flink-connectors</artifactId>
    <version>1.0.0</version>
    <packaging>pom</packaging>
    <name>GIDO Flink Runtime Connectors</name>
    <description>Download Paimon + Flink CDC SQL connectors into /opt/flink/lib</description>

    <properties>
        <project.build.sourceEncoding>UTF-8</project.build.sourceEncoding>
        <flink.version>2.0.1</flink.version>
        <paimon.version>1.3.2</paimon.version>
        <!-- 3.6+ 须带 Flink 行版本（如 3.6.0-1.20）；2.0.1 基座用 Central 可用的 3.5.0 -->
        <flink.cdc.version>3.5.0</flink.cdc.version>
    </properties>

    <repositories>
        <repository>
            <id>maven-central-direct</id>
            <url>https://repo.maven.apache.org/maven2</url>
            <releases><enabled>true</enabled></releases>
            <snapshots><enabled>false</enabled></snapshots>
        </repository>
    </repositories>

    <dependencies>
        <dependency>
            <groupId>org.apache.paimon</groupId>
            <artifactId>paimon-flink-2.0</artifactId>
            <version>${paimon.version}</version>
        </dependency>
        <dependency>
            <groupId>org.apache.flink</groupId>
            <artifactId>flink-sql-connector-mysql-cdc</artifactId>
            <version>${flink.cdc.version}</version>
        </dependency>
        <dependency>
            <groupId>org.apache.flink</groupId>
            <artifactId>flink-sql-connector-postgres-cdc</artifactId>
            <version>${flink.cdc.version}</version>
        </dependency>
        <!-- S3 warehouse / checkpoint（须装 plugins/s3-fs-hadoop，勿与 paimon-s3 同用） -->
        <dependency>
            <groupId>org.apache.flink</groupId>
            <artifactId>flink-s3-fs-hadoop</artifactId>
            <version>${flink.version}</version>
        </dependency>
        <!-- hadoop-common 由 Dockerfile dependency:copy 单独打入（勿经 copy-dependencies 拉传递依赖，
             否则会引入 commons-cli-1.2 等与 Flink 2.0.1 冲突的 jar） -->
    </dependencies>

    <build>
        <plugins>
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-dependency-plugin</artifactId>
                <version>3.7.1</version>
                <executions>
                    <execution>
                        <id>copy-connectors</id>
                        <phase>package</phase>
                        <goals>
                            <goal>copy-dependencies</goal>
                        </goals>
                        <configuration>
                            <outputDirectory>${project.build.directory}/connectors</outputDirectory>
                            <!-- connector JAR 为 compile 作用域 fat jar；勿用 runtime（hadoop 传递依赖会污染 classpath） -->
                            <includeScope>compile</includeScope>
                        </configuration>
                    </execution>
                </executions>
            </plugin>
        </plugins>
    </build>
</project>
