# 可选：Docker Compose backend 连本机 Kind 集群（非生产默认）
#
# 用法：
#   cp gido/docker-compose.kind-local.override.yml.example gido/docker-compose.override.yml
#   cp gido/config/flink-operator.kind-local.env.example 中变量合并进仓库根 .env
#   cd gido && docker compose --env-file ../.env up -d --build backend
#
services:
  backend:
    ports:
      - "${GIDO_BIND_HOST:-0.0.0.0}:${GIDO_FLINK_UI_PORT_RANGE:-22000-22999}:${GIDO_FLINK_UI_TUNNEL_BIND_PORT_RANGE:-32000-32999}"
    environment:
      GIDO_FLINK_K8S_CONTEXT: ${GIDO_FLINK_K8S_CONTEXT:-kind-gido}
      GIDO_FLINK_K8S_KIND_CONTROL_PLANE: ${GIDO_FLINK_K8S_KIND_CONTROL_PLANE:-}
      FLINK_K8S_KUBECONFIG_PATH: ${GIDO_FLINK_K8S_KUBECONFIG_PATH:-/tmp/kube-for-backend}
      GIDO_FLINK_K8S_API_HOST: ${GIDO_FLINK_K8S_API_HOST:-host.docker.internal}
      GIDO_FLINK_K8S_API_PATCH: ${GIDO_FLINK_K8S_API_PATCH:-}
    volumes:
      - ${GIDO_FLINK_K8S_KUBECONFIG_HOST:-${HOME}/.kube/config}:/root/.kube/host-kubeconfig:ro
    networks:
      - default
      - kind

networks:
  kind:
    external: true
    name: kind
