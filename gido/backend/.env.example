# GIDO 后端本地配置（PyCharm / 本机 uvicorn）
# 复制为 backend/.env，勿提交 .env
# Compose 全栈请用仓库根 .env（GIDO_DATABASE_URL）

# --- 元数据库（PostgreSQL）---
DATABASE_URL=postgresql+psycopg2://root:YOUR_PASSWORD@127.0.0.1:5432/gido

# 生产推荐：拆分变量（四项齐全时优先于 DATABASE_URL，见 config.py resolved_database_url）
# INFRA_GIDO_DB_SERVICE_URL=pg.prod.internal:5432
# INFRA_GIDO_DB_SERVICE_USER=gido_writer
# INFRA_GIDO_DB_SERVICE_PASSWORD=your-secret
# INFRA_GIDO_DB_URL=gido

SECRET_KEY=change-me-to-random-string-in-production

# DolphinScheduler
DS_ENABLED=true
DS_URL=http://127.0.0.1:12345/dolphinscheduler
DS_TOKEN=
DS_PROJECT_NAME=GIDO
INTERNAL_TOKEN=

# Flink Session（SQL / 可选 JAR Session 模式）
FLINK_URL=http://127.0.0.1:8081
FLINK_SQL_GATEWAY_URL=http://127.0.0.1:8083
FLINK_UI_URL=http://127.0.0.1:8081
FLINK_GATEWAY_JOBMANAGER_REST_URL=http://127.0.0.1:8081

# Flink Operator（JAR 生产，Docker 连 Kind 时见 gido/config/flink-operator.kind-local.env.example）
# FLINK_OPERATOR_NAMESPACE=flink
# FLINK_OPERATOR_JAR_HTTP_BASE=http://host.docker.internal:8001
# FLINK_OPERATOR_ARTIFACT_TOKEN=
