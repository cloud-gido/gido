# GIDO 后端本地配置示例（复制为 .env，勿提交 .env）
# SPDX-License-Identifier: Apache-2.0

DATABASE_URL=postgresql+psycopg2://root:YOUR_PASSWORD@127.0.0.1:5432/gido
SECRET_KEY=change-me-to-random-string-in-production

# 告警（可选）
ALERT_WEBHOOK_URL=
ALERT_EMAIL=

# DolphinScheduler
DS_ENABLED=true
DS_URL=http://127.0.0.1:12345/dolphinscheduler
DS_TOKEN=
DS_PROJECT_NAME=GIDO
INTERNAL_TOKEN=

# Flink（可选）
FLINK_URL=http://127.0.0.1:8081
FLINK_SQL_GATEWAY_URL=http://127.0.0.1:8083
FLINK_UI_URL=http://127.0.0.1:8081
FLINK_GATEWAY_JOBMANAGER_REST_URL=http://127.0.0.1:8081

# 生产：务必修改默认 admin 密码（init_db 后）
# RESET_ADMIN_PASSWORD=
