# =============================================================================
# 元数据库（PostgreSQL）— 二选一
# =============================================================================
# 方式 A（本地/兼容）：单一 SQLAlchemy URL（用户密码写在串里，不推荐生产）
# Docker：上一级 .env 的 GIDO_DATABASE_URL（host.docker.internal）
# 本机：127.0.0.1
DATABASE_URL=postgresql+psycopg2://root:DolphinPgDev%2172@127.0.0.1:5432/gido

# 方式 B（生产/运维推荐）：拆分注入（与 K8s Secret、INFRA_* 一致；四项齐全时优先于 DATABASE_URL）
# INFRA_GIDO_DB_SERVICE_URL=pg.prod.internal:5432
# 或带库名路径：INFRA_GIDO_DB_SERVICE_URL=postgresql://pg.prod.internal:5432/gido
# INFRA_GIDO_DB_SERVICE_USER=gido_writer
# INFRA_GIDO_DB_SERVICE_PASSWORD=your-secret
# INFRA_GIDO_DB_URL=gido
# 可选：只读账号用户名（预留给只读副本；当前后端进程仍用读写账号连库）
# INFRA_GIDO_DB_SERVICE_READER=gido_reader
