# GIDO + Flink Operator — 生产环境（Backend 与 Flink 同 K8s 集群）
#
# 技术栈：Flink Kubernetes Operator 1.15 + Flink 2.0.1（Session / Operator 统一镜像）
#
# 一键部署：
#   KIND_CLUSTER_NAME=gido GIDO_KIND_LOAD=1 bash k8s/apply-gido-stack.sh
#   kubectl apply -f k8s/flink-operator-rbac.yaml
#   （可选）kubectl apply -f k8s/gido-ingress.yaml
#
# 流程：GIDO UI 上传 JAR → 实时作业选「Flink Operator 生产」→ 提交
# Operator Pod 经 FLINK_OPERATOR_JAR_HTTP_BASE 拉取制品；Backend 经集群 DNS 调 JM REST。

GIDO_FLINK_K8S_APPLICATION_IMAGE=apache/flink:2.0.1-java11
GIDO_FLINK_OPERATOR_IMAGE=apache/flink:2.0.1-java11
GIDO_FLINK_OPERATOR_FLINK_VERSION=v2_0
GIDO_FLINK_K8S_NAMESPACE=flink
GIDO_FLINK_OPERATOR_NAMESPACE=flink
GIDO_FLINK_K8S_REST_EXPOSED_TYPE=LoadBalancer

GIDO_FLINK_OPERATOR_JM_REST_TEMPLATE=http://{deployment_name}-rest.{namespace}.svc.cluster.local:8081

# 浏览器 Flink Web UI（按 Ingress / 对外域名填写）
# GIDO_FLINK_OPERATOR_UI_URL_TEMPLATE=https://{deployment_name}-flink.your-company.com
# 或集群内 GIDO 代理（无 Ingress 时）：GIDO_FLINK_OPERATOR_UI_PROXY_ENABLED=true

GIDO_FLINK_OPERATOR_JAR_HTTP_BASE=http://backend.gido.svc.cluster.local:8001
GIDO_FLINK_OPERATOR_ARTIFACT_TOKEN=<random-secret-rotate-in-prod>

# GIDO_FLINK_OPERATOR_JAR_S3_PREFIX=s3://your-bucket/gido-jars
# GIDO_FLINK_OPERATOR_CHECKPOINT_DIR=s3://your-bucket/flink-checkpoints

GIDO_FLINK_OPERATOR_DEV_LOCAL=false
GIDO_FLINK_OPERATOR_AUTO_UI_TUNNEL=false
