# GIDO + Flink Operator — 本机 Kind/Mac 开发覆盖（勿用于生产）
#
# 技术栈：Operator 1.15 + Flink 2.0.1（与 Compose Session / k8s/gido.yaml 一致）
#
# 与 docker-compose.kind-local.override.yml.example 配套使用。
#
# 1) cp gido/docker-compose.kind-local.override.yml.example gido/docker-compose.override.yml
# 2) 将本文件变量合并进仓库根 .env
# 3) Kind：bash k8s/create-kind-gido.sh && kubectl apply -f k8s/flink-operator-rbac.yaml
# 4) cd gido && docker compose --env-file ../.env up -d --build backend
#
# 生产一键部署请用 k8s/apply-gido-stack.sh + gido/config/flink-operator.production.env.example

GIDO_FLINK_K8S_APPLICATION_IMAGE=apache/flink:2.0.1-java11
GIDO_FLINK_OPERATOR_IMAGE=apache/flink:2.0.1-java11
GIDO_FLINK_OPERATOR_FLINK_VERSION=v2_0
GIDO_FLINK_K8S_CONTEXT=kind-gido
GIDO_FLINK_K8S_KIND_CONTROL_PLANE=gido-control-plane
GIDO_FLINK_K8S_KUBECONFIG_PATH=/tmp/kube-for-backend
GIDO_FLINK_K8S_KUBECONFIG_HOST=${HOME}/.kube/config
GIDO_FLINK_K8S_REST_EXPOSED_TYPE=NodePort
GIDO_FLINK_K8S_JM_NODEPORT_HOST=host.docker.internal
GIDO_FLINK_K8S_JM_NODEPORT_BROWSER_HOST=127.0.0.1

GIDO_FLINK_OPERATOR_JAR_HTTP_BASE=http://host.docker.internal:8001
GIDO_FLINK_OPERATOR_ARTIFACT_TOKEN=gido-kind-artifact-dev

GIDO_FLINK_OPERATOR_DEV_LOCAL=true
GIDO_FLINK_OPERATOR_AUTO_UI_TUNNEL=true
GIDO_FLINK_OPERATOR_UI_LOCAL_PORT_BASE=22000
GIDO_FLINK_OPERATOR_UI_TUNNEL_BIND_PORT_BASE=32000
GIDO_FLINK_UI_PORT_RANGE=22000-22999
GIDO_FLINK_UI_TUNNEL_BIND_PORT_RANGE=32000-32999
