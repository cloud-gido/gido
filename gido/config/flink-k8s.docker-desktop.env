# =============================================================================
# Docker Desktop Kubernetes — 环境变量模板（Flink 仅由仓库根 k8s/flink.yaml 部署）
# =============================================================================
# 用法：将需要的行复制到 bigdata_all/.env（docker compose）或 gido/backend/.env（本机 PyCharm），
# 或：docker compose --env-file ./config/flink-k8s.docker-desktop.env …
#
# backend 跑在 Docker 容器内且需 K8s API（Application / NodePort 解析）时：
#   自建 docker-compose.override.yml（勿提交仓库）为 backend 增加 volume，例如：
#     volumes:
#       - ${HOME}/.kube/config:/root/.kube/host-kubeconfig:ro
#   启动后 entrypoint 会把 host-kubeconfig 复制到 /tmp 并（默认）把 127.0.0.1:随机端口 换成 kubernetes.docker.internal:6443。
#
# 关闭 apiserver 地址自动替换：GIDO_FLINK_K8S_API_PATCH=disable
# 默认（不设或设空）：把 https://127.0.0.1:<任意端口> / https://localhost:<任意端口>
# 换成 https://kubernetes.docker.internal:6443（适配 Docker Desktop 随机端口）。
#
# 不需要 Application / NodePort 自动解析时：注释或删除下面 FLINK_K8S_* 即可。
# =============================================================================
#
# 默认端口（与 k8s/flink.yaml 一致）
#   K8s Session：JM 宿主 8081（Service LoadBalancer）；Gateway 集群内 8083；可选宿主 NodePort 32483（见 k8s/flink-sql-gateway-nodeport.yaml）。
#   K8s Application：每作业 JM REST Service 的 NodePort 由集群分配（非固定），后端用 FLINK_K8S_JM_NODEPORT_HOST + 自动解析或 JM_REST_TEMPLATE。
#
# override 里挂载到 /root/.kube/host-kubeconfig 的宿主机路径（Windows 请改成绝对路径）
# GIDO_FLINK_K8S_KUBECONFIG_HOST=/Users/你的用户名/.kube/config

# 与 Flink Session（k8s/flink.yaml）同一镜像族，便于 Session / Application 行为一致
GIDO_FLINK_K8S_APPLICATION_IMAGE=apache/flink:2.0.1-java11

# 与 kubectl 里 Flink 所在命名空间一致（你当前为 flink）
GIDO_FLINK_K8S_NAMESPACE=flink

# 后端从 Docker 容器访问 JM 的 NodePort 时用宿主机别名（本机 PyCharm 跑 backend 请改 127.0.0.1）
# GIDO_FLINK_K8S_JM_NODEPORT_HOST=127.0.0.1

# 多集群时指定 kubectl context；单集群可留空
# GIDO_FLINK_K8S_CONTEXT=docker-desktop

# 后端从容器访问 JM NodePort 时连到宿主机（Docker Desktop 可用；Linux 纯 Docker 可改为 172.17.0.1）
GIDO_FLINK_K8S_JM_NODEPORT_HOST=host.docker.internal

# 提交后 GIDO 后端轮询 JM 的地址模板，须含 {cluster_id}。
# 若后端跑在宿主机：ClusterIP 主机名通常不可解析，请用「kubectl get svc」查看 NodePort 后，临时改为
#   http://127.0.0.1:<nodePort>
# 并把下面一行取消注释（每次 cluster_id 变化时 nodePort 可能变，生产建议后端跑在集群内或使用 Ingress）。
# GIDO_FLINK_K8S_APPLICATION_JM_REST_TEMPLATE=http://{cluster_id}-rest.flink.svc.cluster.local:8081
