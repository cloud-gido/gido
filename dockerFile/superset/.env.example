# 复制为 .env：cp superset/.env.example superset/.env

# ---------- Superset 镜像（国内推荐 DaoCloud，勿直连 docker.io）----------
# 先拉取：bash superset/pull-image.sh
SUPERSET_IMAGE=docker.m.daocloud.io/apache/superset:4.0.2
# 备选：m.daocloud.io/docker.io/apache/superset:4.0.2

# ---------- 复用 Dolphin 的 PostgreSQL（推荐）----------
# 先建库：bash superset/prepare-external-pg.sh
# 与 dolphin compose 同网时主机名用 postgres（服务名），不要用 127.0.0.1
DATABASE_URL=postgresql+psycopg2://root:DolphinPgDev%2172@postgres:5432/superset

# Dolphin 网络名（docker network ls 里一般为 dolphinscheduler-docker_default）
SUPERSET_DOCKER_NETWORK=dolphinscheduler-docker_default

# ---------- 复用已有 Redis（7.4-alpine）----------
# A) Redis 映射到宿主机 6379：
REDIS_HOST=host.docker.internal
REDIS_PORT=6379

# B) Redis 容器与 Superset 在同一自定义网络时，填容器名/服务名，例如：
# REDIS_HOST=my-redis
# REDIS_PORT=6379

# 若 Redis 启用了 requirepass：
# REDIS_PASSWORD=your_redis_password

# 与别的服务共用同一 Redis 时，用不同 DB 号避免 key 冲突（默认 0/1/2）
REDIS_DB_CELERY_BROKER=0
REDIS_DB_CELERY_RESULT=1
REDIS_DB_CACHE=2

# ---------- 管理员与密钥 ----------
SUPERSET_SECRET_KEY=请改为随机长字符串
SUPERSET_ADMIN_USERNAME=admin
SUPERSET_ADMIN_PASSWORD=admin
SUPERSET_ADMIN_EMAIL=admin@gido.local

# Web 端口
SUPERSET_PORT=8088

# 界面语言：zh（简体，默认）| en
# SUPERSET_LOCALE=zh

# 需要 SQL Lab 异步 / 邮件报表等再启用 Celery：
# COMPOSE_PROFILES=celery
