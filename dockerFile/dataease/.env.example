# 复制为 .env：cp dataease/.env.example dataease/.env

DE_PORT=8100

# DataEase 镜像：首次须 pull；本地已有后再设 DATAEASE_PULL_POLICY=never
# bash dataease/pull-image.sh
DATAEASE_IMAGE=registry.cn-qingdao.aliyuncs.com/dataease/dataease:v2.10.11
# DATAEASE_PULL_POLICY=never

# ---------- 复用已有 MySQL（mysql:8.4 等，映射宿主机 3306 时）----------
DE_MYSQL_HOST=host.docker.internal
DE_MYSQL_PORT=3306
DE_MYSQL_DB=dataease
DE_MYSQL_USER=root
DE_MYSQL_PASSWORD=请改为你的MySQL_root密码

# MySQL 容器与 DataEase 在同一 Docker 网络时，改为容器名/服务名，例如：
# DE_MYSQL_HOST=my-mysql
# DATAEASE_DOCKER_NETWORK=你的网络名
# DATAEASE_DOCKER_NETWORK_EXTERNAL=true

# 【元库 vs 数据源】平台元数据仅支持 MySQL；PostgreSQL 仅作「数据源」查 GIDO 等业务库。

# ---------- GIDO 元库（PG 数据源，在 UI 里添加）----------
# jdbc:postgresql://host.docker.internal:5432/gido
# 用户 root，密码 DolphinPgDev!72
